# Required

# Long random secret. Generate with: openssl rand -hex 32
RELAY_API_KEY=change-me

# Comma-separated list of upstream hosts the relay is allowed to call.
# Match is exact OR ".suffix" (e.g. "api.example.com" or ".example.com").
ALLOWED_HOSTS=api.example-provider.com

# Optional

# Bind address & port for the Node app (Caddy proxies to this).
HOST=0.0.0.0
PORT=3000

# Logging
LOG_LEVEL=info

# Limits
MAX_BODY_BYTES=1048576           # 1 MiB
UPSTREAM_TIMEOUT_MS=15000
MAX_REDIRECTS=0                  # 0 = do not follow

# Rate limiting (per API key)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# Reported in /v1/health (set in CI/CD to the commit SHA)
RELAY_VERSION=dev

RELAY_DOMAIN=
RELAY_ACME_EMAIL=
RELAY_IMAGE=